{
  "name": "@shipmyform/svelte",
  "version": "0.1.0",
  "description": "Svelte store and action for submitting forms to ShipMyForm.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipMyForm/shipmyform-js.git",
    "directory": "packages/svelte"
  },
  "keywords": ["shipmyform", "forms", "svelte"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external svelte --external svelte/store"
  },
  "dependencies": {
    "@shipmyform/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": ">=4"
  },
  "devDependencies": {
    "svelte": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
